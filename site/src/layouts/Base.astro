---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Надеждност на градския транспорт в София — изчислено от живите GTFS данни.' } =
  Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} — Sofia On Time</title>
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="site-logo" aria-label="Sofia On Time — начална страница">
        <img src={`${base}logo.svg`} alt="Sofia On Time" height="44" />
      </a>
      <nav>
        <a href={`${base}methodology/`}>Методология</a>
        <a href={`${base}feed-health/`}>Данни</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Данните се актуализират всяка нощ. Без бисквитки и проследяване.</p>
    </footer>
  </body>
</html>
